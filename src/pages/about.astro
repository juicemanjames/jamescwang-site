---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { site, about } from '../data/load';
---
<BaseLayout title="About Me">
  <div class="container">
    <div class="row">
      <Sidebar />
      <div class="content">
        <img src={about.heroBanner} alt="Company logos" style="width:100%; border-radius:5px; margin-bottom:20px;" />

        <h1>{about.title}</h1>

        <div style="margin-bottom:20px;">
          <a href={about.linkedinUrl} class="btn">My LinkedIn</a>
          <a href={site.resumePath} target="_blank" class="btn">My Resume</a>
        </div>

        {about.sections.map(section => (
          <>
            {section.image && (
              <>
                <img
                  src={section.image}
                  alt={section.imageAlt || ''}
                  class="about-photo"
                  style={section.imageMaxWidth ? `max-width:${section.imageMaxWidth}; width:100%; border-radius:3px; margin:15px 0;` : undefined}
                />
                {section.caption && <div class="about-caption">{section.caption}</div>}
              </>
            )}

            {section.images && section.images.map(img => (
              <>
                <img
                  src={img.src}
                  alt={img.alt}
                  class="about-photo"
                  style={img.fullWidth ? 'width:100%; border-radius:3px; margin:15px 0;' : undefined}
                />
                {img.caption && <div class="about-caption">{img.caption}</div>}
              </>
            ))}

            <h3 set:html={section.text} />

            {section.video && (
              <>
                <div class="video-embed">
                  <iframe src={`https://www.youtube.com/embed/${section.video.youtubeId}`} allowfullscreen></iframe>
                </div>
                <div class="about-caption">{section.video.caption}</div>
              </>
            )}
          </>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
